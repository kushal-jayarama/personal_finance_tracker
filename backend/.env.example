APP_NAME=AI Finance Tracker API
DATABASE_URL=sqlite:///./finance_tracker.db
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
ENCRYPTION_KEY=replace-with-long-secret

# LLM settings (Ollama-first)
ENABLE_REMOTE_LLM=True
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=ollama
OLLAMA_MODEL=qwen2.5:7b

# optional legacy OpenAI aliases (not required for Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=


# uvicorn app.main:app --port 8005 --reload
# npm run dev